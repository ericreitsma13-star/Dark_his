# OpenRouter API key — get at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here

# Script generation model (~$0.001/video)
#   meta-llama/llama-3.3-70b-instruct  (recommended — best quality/price)
#   google/gemini-2.5-flash            (Google option)
#   qwen/qwen3.5-flash-02-23           (cheapest)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# From Google Cloud Console → APIs & Services → Credentials
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# Optional: path to a background music .mp3 file
BACKGROUND_MUSIC_PATH=assets/music/background.mp3

# TTS engine: "edge-tts" (free, CPU, no GPU needed) or "chatterbox" (GPU, voice cloning)
TTS_ENGINE=edge-tts

# Chatterbox only: path to a 10-20s WAV of the voice you want to clone
# CHATTERBOX_VOICE_REF=/path/to/narrator_sample.wav

# Image engine: "pollinations" (free, cloud) or "local-flux" (GPU, faster, higher quality)
IMAGE_ENGINE=pollinations
